    @template mod_elediacheckin/present

    Chrome-less popup layout for screen-sharing in video calls. Loaded via
    window.open() from view.php. Shares the "no categories, no ziel-chip,
    ziel-picker only when multi, answer toggle only when hasanswer" rules
    with the normal view (see docs/display-modes-mockup-v2.html).

    Context variables required for this template:
      * cmid              int
      * externalid        string   unique content-pack ID for JS sync
      * hasquestion       bool
      * question          { frage, antwort, hasanswer, isquote, hasauthor, author }
      * multiziel         bool
      * zielbuttons       array of { label, active, url }
      * hasprev           bool
      * prevquestionurl   string
      * nextquestionurl   string
      * exhausted         bool
      * strnext           localised "Nächste Frage"
      * strprev           localised "Zurück"
      * strshowanswer     localised "Antwort anzeigen"
      * strnone           localised "Keine Fragen verfügbar"
      * strexhausted      localised "Alle Fragen wurden gezeigt."
      * strclose          localised "Schließen"

    Example context (json):
    {
        "cmid": 42,
        "externalid": "abc-123",
        "hasquestion": true,
        "question": {
            "frage": "Was nimmst du aus dieser Session mit?",
            "antwort": "Eine neue Perspektive.",
            "hasanswer": 1,
            "isquote": false,
            "hasauthor": false,
            "author": ""
        },
        "multiziel": true,
        "zielbuttons": [
            {"label":"Check-in","active":true,"url":"present.php?id=42&activeziel=checkin"},
            {"label":"Check-out","active":false,"url":"present.php?id=42&activeziel=checkout"}
        ],
        "hasprev": true,
        "prevquestionurl": "present.php?id=42&activeziel=checkin&r=0",
        "nextquestionurl": "present.php?id=42&activeziel=checkin&r=1",
        "exhausted": false,
        "strnext": "Nächste Frage",
        "strprev": "Zurück",
        "strshowanswer": "Antwort anzeigen",
        "strnone": "Keine Fragen verfügbar",
        "strexhausted": "Alle Fragen wurden gezeigt.",
        "strclose": "Schließen"
    }
}}
<div id="mod-elediacheckin-present" class="elediacheckin-present" data-cmid="{{cmid}}" data-externalid="{{externalid}}">
    <div class="elediacheckin-present-header">
        <div class="elediacheckin-present-ziel-picker">
            {{#multiziel}}
                {{#zielbuttons}}
                    <a class="elediacheckin-present-ziel-btn {{#active}}is-active{{/active}}"
                        href="{{url}}">{{label}}</a>
                {{/zielbuttons}}
            {{/multiziel}}
        </div>
        <button type="button" class="elediacheckin-present-close"
            data-action="close-present"
            title="{{strclose}}"
            aria-label="{{strclose}}">&times;</button>
    </div>

    {{#hasquestion}}
        <div class="elediacheckin-present-middle">
            <p class="elediacheckin-present-question {{#question.isquote}}elediacheckin-present-question--quote{{/question.isquote}}">{{question.frage}}</p>
            {{#question.hasauthor}}
                <p class="elediacheckin-present-author">— {{question.author}}</p>
            {{/question.hasauthor}}
        </div>
        <div class="elediacheckin-present-footer">
            {{#question.hasanswer}}
                <button type="button"
                    class="elediacheckin-present-btn"
                    data-action="toggle-present-answer"
                    data-answer="{{question.antwort}}">
                    {{strshowanswer}}
                </button>
            {{/question.hasanswer}}
            {{#hasprev}}
                <a href="{{prevquestionurl}}"
                    class="elediacheckin-present-btn">{{strprev}}</a>
            {{/hasprev}}
            <a href="{{nextquestionurl}}"
                class="elediacheckin-present-btn is-primary">{{strnext}}</a>
        </div>
        {{#question.hasanswer}}
            <div class="elediacheckin-present-answer" data-region="present-answer" hidden>
                {{question.antwort}}
            </div>
        {{/question.hasanswer}}
    {{/hasquestion}}

    {{^hasquestion}}
        <div class="elediacheckin-present-middle">
            {{#exhausted}}
                <p class="elediacheckin-present-empty">{{strexhausted}}</p>
            {{/exhausted}}
            {{^exhausted}}
                <p class="elediacheckin-present-empty">{{strnone}}</p>
            {{/exhausted}}
        </div>
    {{/hasquestion}}
</div>
