    @template mod_elediacheckin/view

    The main view for an elediacheckin activity.

    Classes required for JS: data-region="elediacheckin-question"

    Context variables required for this template:
    * cmid: course module id
    * mode: one of both|checkin|checkout
    * shownav: bool
    * showother: bool
    * showfilter: bool
    * hasquestion: bool
    * question: object with text, type, lang
    * strnew, strnone: localised labels

    Example context (json):
    {
        "cmid": 42,
        "mode": "both",
        "shownav": true,
        "showother": true,
        "showfilter": false,
        "hasquestion": true,
        "question": { "text": "Mit welcher Energie bist du heute hier?", "type": "checkin", "lang": "de" },
        "strnew": "Andere Frage",
        "strnone": "Keine Fragen verfügbar"
    }
}}
<div id="mod-elediacheckin-root" class="elediacheckin-stage" data-cmid="{{cmid}}">
    <div class="card mb-4">
        <div class="card-body elediacheckin-question-card" data-region="elediacheckin-question">
            {{#hasquestion}}
                <div class="elediacheckin-mode-label">{{question.type}} · {{question.lang}}</div>
                <p class="elediacheckin-question-text">{{question.text}}</p>
            {{/hasquestion}}
            {{^hasquestion}}
                <div class="alert alert-info mb-0" role="status">{{strnone}}</div>
            {{/hasquestion}}
        </div>
    </div>

    <div class="elediacheckin-controls" role="group" aria-label="Check-in controls">
        {{#showother}}
            <button type="button" class="btn btn-primary" data-action="new-question">
                {{strnew}}
            </button>
        {{/showother}}
    </div>
</div>
