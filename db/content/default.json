    {
      "id": "funfact-0006",
      "ziel": "funfact",
      "kategorie": [
        "alltag"
      ],
      "frage": "Warum sind Bananen eigentlich Beeren, Erdbeeren aber nicht?",
      "zielgruppe": [
        "fuehrungskraefte",
        "grundschule",
        "team"
      ],
      "kontext": [
        "arbeit",
        "hochschule",
        "privat",
        "schule"
      ],
      "hat_antwort": true,
      "sprache": "de",
      "lizenz": "CC-BY-4.0",
      "version": "1",
      "status": "published",
      "created_at": "2026-04-05T10:00:00Z",
      "updated_at": "2026-04-05T10:00:00Z",
      "autor": "eLeDia Redaktion",
      "antwort": "Botanisch definiert sich eine Beere als Frucht, die aus einem einzigen Fruchtknoten entsteht und eine fleischige Schale mit darin eingeschlossenen Samen hat — das trifft auf Bananen zu. Erdbeeren dagegen sind Sammelnussfrüchte: Die 'Samen' außen sind die eigentlichen Früchte, der rote Teil ist der verdickte Blütenboden."
    },
    {
      "id": "funfact-0007",
      "ziel": "funfact",
      "kategorie": [
        "natur"
      ],
      "frage": "Wie viele Farben kann das menschliche Auge unterscheiden?",
      "zielgruppe": [
        "fuehrungskraefte",
        "grundschule",
        "team"
      ],
      "kontext": [
        "arbeit",
        "hochschule",
        "privat",
        "schule"
      ],
      "hat_antwort": true,
      "sprache": "de",
      "lizenz": "CC-BY-4.0",
      "version": "1",
      "status": "published",
      "created_at": "2026-04-05T10:00:00Z",
      "updated_at": "2026-04-05T10:00:00Z",
      "autor": "eLeDia Redaktion",
      "antwort": "Schätzungen gehen von etwa 2 bis 10 Millionen Farbtönen aus. Ein Fangschreckenkrebs (Mantis Shrimp) hingegen hat 16 Arten von Farbrezeptoren (wir haben drei) — und sieht trotzdem Farben vermutlich nicht so differenziert wie wir, weil sein Gehirn sie anders verarbeitet."
    },
